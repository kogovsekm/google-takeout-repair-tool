{
  "name": "google-takeout-repair-tool",
  "private": true,
  "version": "1.0.4",
  "description": "Desktop utility for repairing and organizing Google Takeout photo and video exports locally.",
  "author": "Matija Kogovsek",
  "license": "MIT",
  "homepage": "https://github.com/kogovsekm/google-takeout-repair-tool",
  "repository": {
    "type": "git",
    "url": "https://github.com/kogovsekm/google-takeout-repair-tool.git"
  },
  "bugs": {
    "url": "https://github.com/kogovsekm/google-takeout-repair-tool/issues"
  },
  "keywords": [
    "google-takeout",
    "takeout",
    "metadata",
    "photo-repair",
    "media-organizer",
    "exif",
    "electron",
    "desktop-app"
  ],
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "concurrently -k \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch",
    "dev:electron:run": "wait-on http://localhost:5173 dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "release:all": "node scripts/release-all.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "npm run build:electron && node scripts/benchmark.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/figtree": "5.2.10",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-dialog": "1.1.15",
    "date-fns": "4.1.0",
    "exiftool-vendored": "35.19.0",
    "lucide-react": "^1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.21",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "41.5.0",
    "electron-builder": "26.8.1",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wait-on": "9.0.5"
  },
  "build": {
    "appId": "com.googletakeoutrepairtool.desktop",
    "productName": "Google Takeout Repair Tool",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/exiftool-vendored.pl/**",
      "**/node_modules/exiftool-vendored.exe/**"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.photography"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icons/icon-linux.png",
      "target": [
        "AppImage"
      ],
      "category": "Graphics"
    }
  }
}
